# Twitch Integration Configuration
# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control!

# Twitch OAuth Token
# Get one from: https://twitchtokengenerator.com/ (select "Bot Chat Token")
# Or use the Twitch Developer Console: https://dev.twitch.tv/console
TWITCH_ACCESS_TOKEN=oauth:your_token_here

# Optional: Client ID (only needed for some advanced features)
# TWITCH_CLIENT_ID=your_client_id_here

# Optional: Client Secret (only needed for token refresh)
# TWITCH_CLIENT_SECRET=your_client_secret_here



OPENROUTER_API_KEY=your_openrouter_api_key_here
REMBG_API_KEY=your_rembg_api_key_here # you can get one for free at https://www.rembg.com/ after signing up